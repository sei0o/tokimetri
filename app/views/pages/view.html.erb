<% content_for :head do %>
  <style>
    .calendar-container {
      margin-top: 30px;
      margin-bottom: 50px;
    }
    
    .calendar-legend {
      display: flex;
      flex-wrap: wrap;
      margin-bottom: 15px;
      gap: 10px;
    }
    
    .legend-item {
      display: flex;
      align-items: center;
      margin-right: 15px;
    }
    
    .legend-color {
      width: 15px;
      height: 15px;
      margin-right: 5px;
      border-radius: 3px;
    }
    
    .calendar-controls {
      display: flex;
      justify-content: space-between;
      margin-bottom: 15px;
    }
    
    .view-buttons {
      display: flex;
      gap: 10px;
    }
    
    .view-button {
      padding: 5px 10px;
      background-color: #f0f0f0;
      border: 1px solid #ddd;
      border-radius: 4px;
      cursor: pointer;
    }
    
    .view-button.active {
      background-color: #007bff;
      color: white;
      border-color: #007bff;
    }
    
    .date-navigation {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .nav-button {
      padding: 5px 10px;
      background-color: #f0f0f0;
      border: 1px solid #ddd;
      border-radius: 4px;
      cursor: pointer;
    }
    
    .current-date-range {
      font-weight: bold;
    }
    
    .raw-data-toggle {
      margin-top: 20px;
      margin-bottom: 10px;
    }
    
    .raw-data {
      display: none;
      padding: 15px;
      background-color: #f9f9f9;
      border: 1px solid #ddd;
      border-radius: 4px;
      margin-bottom: 20px;
    }
    
    .raw-data.visible {
      display: block;
    }
  </style>
<% end %>

<% content_for :title, "view" %>



<style>
  .hday-line {
    display: flex;
    margin-bottom: 10px;
  }

  .hday {
    width: 100%;
    height: 1.5rem;
    background-color: #f0f0f0;
    position: relative;
  }

  .hday-slot {
    position: absolute;
    top: 0;
    height: 100%;
    border-right: 2px solid #fff;    
    box-sizing: border-box;
  }
  
  .date-header {
    font-weight: bold;
    width: 3em;
    height: 1.5rem;
    line-height: 1.5rem;
  }
  
  .activity-details {
    margin-top: 15px;
    margin-bottom: 15px;
  }

  .hday-hour {
    height: 0.3rem;
    background-color: #aaa;
    margin-top: 20px;
  }

  .hday-slot-hour::after {
    content: attr(data-hour);
    position: absolute;
    top: -1rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
  }

</style>

<div class="hday-line">
  <div class="date-header"></div>
  <div class="hday hday-hour">
    <% 0.upto(23) do |h| %>
      <div class="hday-slot hday-slot-hour" 
           style="left: calc(100% * <%= h %> / 24); 
                  width: 1px;
                  background-color: black;"
            data-hour="<%= h %>"></div>
    <% end %>
  </div>
</div>

<% activities_by_date(@pages).each do |date, v| %>
  <div class="hday-line">
    <div class="date-header">
      <a href="/day/<%= date.to_date.strftime("%Y%m%d") %>">
        <%= date.to_date.strftime("%m/%d") %>
      </a>
    </div>
    <div class="hday">
      <% v.each do |line| %>
        <% position = calculate_hday_slot_position(line, date) %>
        <% next unless position %>
    
        <div class="hday-slot" 
             style="left: calc(100% * <%= position[:left_pos] %>); 
                    width: calc(100% * <%= position[:width] %>);
                    background-color: <%= @categories[position[:category]] %>;" 
             title="<%= position[:title] %>"></div>
      <% end %>
    </div>
  </div>
<% end %>