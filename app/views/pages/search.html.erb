<style>
  .day-separator {
    padding-top: 1rem;
  }

  .match {
    background-color: lightyellow;
    font-weight: bold;
    margin: 0 0.3rem;
  }
</style>

<% q = params[:q] %>

<%= form_with url: search_path, method: :get, local: true do |f| %>
  <%= f.search_field :q, value: q, placeholder: "検索ワードを入力" %>
  <%= f.submit "検索" %>
<% end %>

<% if q.present? %>
  <% if @stats %>
    <div style="background-color: #f0f0f0; padding: 10px; margin: 10px 0; border-radius: 4px;">
      <strong>統計情報</strong><br>
      回数: <%= @stats[:count] %>回 | 
      平均: <%= minutes_to_hm(@stats[:avg]) %> | 
      中央値: <%= minutes_to_hm(@stats[:median]) %> | 
      標準偏差: <%= minutes_to_hm(@stats[:std_dev]) %><br>
      範囲: <%= minutes_to_hm(@stats[:min]) %> - <%= minutes_to_hm(@stats[:max]) %>
    </div>
  <% end %>
  
  <% if @heatmap_data&.any? %>
    <%
      cell = 13
      pad_left = 22
      pad_top = 18
      start_date = @heatmap_data.keys.min
      end_date   = @heatmap_data.keys.max
      start_sun  = start_date - start_date.wday
      end_sat    = end_date + (6 - end_date.wday)
      weeks      = ((end_sat - start_sun).to_i / 7) + 1
      max_hours  = @heatmap_data.values.max
      svg_w = pad_left + weeks * cell
      svg_h = pad_top + 7 * cell
    %>
    <svg width="<%= svg_w %>" height="<%= svg_h %>" style="display:block; margin: 1rem 0; overflow: visible;">
      <% prev_month = nil %>
      <% (0...weeks).each do |w| %>
        <% d = start_sun + w * 7 %>
        <% if d.month != prev_month %>
          <% prev_month = d.month %>
          <text x="<%= pad_left + w * cell %>" y="<%= pad_top - 5 %>" font-size="9" fill="#888"><%= d.strftime("%-m月") %></text>
        <% end %>
      <% end %>
      <% (0...weeks).each do |w| %>
        <% (0...7).each do |d| %>
          <% date  = start_sun + (w * 7 + d).days %>
          <% hours = @heatmap_data[date] || 0 %>
          <% cx = pad_left + w * cell + cell / 2 %>
          <% cy = pad_top  + d * cell + cell / 2 %>
          <% if hours > 0 %>
            <% r = (Math.sqrt(hours / max_hours) * 5.5).round(1).clamp(1.0, 5.5) %>
            <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= r %>" fill="#333">
              <title><%= date.strftime("%Y-%m-%d") %>: <%= hours.round(1) %>h</title>
            </circle>
          <% else %>
            <circle cx="<%= cx %>" cy="<%= cy %>" r="1" fill="#ddd" />
          <% end %>
        <% end %>
      <% end %>
    </svg>
  <% end %>

  <% if @records.any? %>
    <table>
      <thead>
        <tr>
          <th><input type="checkbox" style="visibility: hidden;"></th>
          <th>Start</th>
          <th>WST8</th>
          <th>Duration</th>
          <th>What</th>
          <th>Category</th>
        </tr>
      </thead>
      <tbody>
        <% last_date = nil %>
        <% @records.each do |record| %>
          <% if record.page.date != last_date %>
            <% last_date = record.page.date %>
            <tr>
              <td colspan="7" class="day-separator">
                <%= link_to record.page.date.strftime("%Y-%m-%d"), date_path(record.page.date.strftime("%Y%m%d")) %>
              </td>
            </tr>
          <% end %>
          <%= render partial: "record_row", locals: { record: record, categories: @categories, cap_height: false } %>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <% if @matches.any? %>
    <h2>全文検索</h2>
    <% @matches.each do |match| %>
      <div style="margin-bottom: 20px;">
        <h3><%= link_to match[:page].date.strftime("%Y-%m-%d"), date_path(match[:page].date.strftime("%Y%m%d")) %></h3>
        <% match[:matches].each do |range| %>
          <p>
            <%= range.join("<br>").gsub(q, "<span class='match'>#{q}</span>").html_safe %>
          </p>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
