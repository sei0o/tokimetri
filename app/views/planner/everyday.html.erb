<div class="planner">
  <div class="panel">
    <h1>毎日のタスク</h1>
  </div>

  <div class="panel">
    <h2>朝</h2>
    <div id="weather" class="weather-note">
      <div class="summary"></div>
      <div class="temps"></div>
    </div>
    <tasks>
      <task>起きる</task>
      <task>カーテンを開ける</task>
      <task>なるべく早くコーヒーを入れる</task>
      <task>顔洗う</task>
      <task>日焼け止め塗る</task>
      <task>飯食う</task>
      <task>薬飲む</task>
      <task>歯を磨く</task>
      <task id="today-garbage"><span>ゴミ出す</span></task>
      <task id="sat-clean"><a href="/planner/clean">週末の掃除</a></task>
    </tasks>
    <pre>朝8時までに出しましょう
水 → 燃えるごみ
木曜日は古紙・プラスチック
第一・第三金曜日は不燃ごみ・電池
土曜日は燃えるごみ＋ビンカンPET</pre>
  </div>

  <div class="panel">
    <h2>出かける</h2>
    <tasks id="leave-home">
      <task>ハンカチを持つ</task>
      <task>着替える（昨日替えた靴下を履く）</task>
      <task class="if-rain">傘を持つ</task>
      <task>カバンにものいれる（PC、財布、スマホ）</task>
    </tasks>
  </div>

  <div class="panel">
    <h2>夜</h2>
    <tasks>
      <task>スマホの電源を落とす</task>
      <task>掃除機かける (5min)</task>
      遅すぎると「隣に迷惑かな…」と思ってかけなくなる
      <task>風呂に入る 20min</task>
      <task>下着と靴下を変える</task>
      <task>保湿をする（顔、脇、身体）</task>
      <task>食事（<span id="dinner">?</span>）を作る・食べる 60min</task>
      <task id="tomorrow-garbage"><span>明日のゴミを出す</span></task>
      <task>明日の予定を確認する</task>
      <task>歯を磨く</task>
      <task>寝る</task>
    </tasks>
  </div>
</div>

<script type="module">
class TaskElement extends HTMLElement {
  connectedCallback() {
    const content = this.innerHTML;
    const id = this.id ? ` id="${this.id}"` : '';
    const cls = this.className ? ` class="${this.className}"` : '';
    this.outerHTML = `<task-item${id}${cls}><label><input type="checkbox"><span>${content}</span></label></task-item>`;
  }
}
customElements.define('task-item', class extends HTMLElement {});

document.querySelectorAll('task').forEach(el => {
  const item = document.createElement('task-item');
  item.innerHTML = `<label><input type="checkbox"><span>${el.innerHTML}</span></label>`;
  if (el.id) item.id = el.id;
  if (el.className) item.className = el.className;
  el.replaceWith(item);
});

document.querySelectorAll('task-item input').forEach(cb => {
  cb.addEventListener('change', () => {
    cb.closest('task-item').classList.toggle('done', cb.checked);
  });
});

function setRainVisibility(rainSoon) {
  document.querySelectorAll('.if-rain').forEach(el => { el.hidden = !rainSoon; });
}

async function loadWeather() {
  const weatherEl = document.getElementById('weather');
  const url = 'https://api.open-meteo.com/v1/forecast?latitude=35.732&longitude=139.74&hourly=precipitation,precipitation_probability,temperature_2m&forecast_days=1&timezone=Asia%2FTokyo';
  try {
    const data = await (await fetch(url)).json();
    const hours = data.hourly?.time || [];
    const precip = data.hourly?.precipitation || [];
    const prob = data.hourly?.precipitation_probability || [];
    const temps = data.hourly?.temperature_2m || [];
    const now = new Date();
    const limit = new Date(now.getTime() + 12 * 60 * 60 * 1000);
    const rainPeriods = [];
    for (let i = 0; i < hours.length; i++) {
      const t = new Date(hours[i]);
      if (t <= now || t > limit) continue;
      if ((precip[i] || 0) > 0) rainPeriods.push({ hour: t.getHours(), mm: precip[i], prob: prob[i] || 0 });
    }
    const rainSoon = rainPeriods.length > 0;
    const validTemps = temps.filter(t => typeof t === 'number');
    const maxTemp = Math.round(Math.max(...validTemps));
    const minTemp = Math.round(Math.min(...validTemps));

    let summary;
    if (!rainSoon) {
      summary = '天気は大きく崩れなさそう';
    } else {
      const total = rainPeriods.reduce((s, p) => s + p.mm, 0);
      const maxProb = Math.max(...rainPeriods.map(p => p.prob));
      const s = rainPeriods[0].hour, e = rainPeriods[rainPeriods.length - 1].hour;
      summary = `雨が降りそう（${s === e ? `${s}時頃` : `${s}〜${e}時頃`}、${total.toFixed(1)}mm、確率${maxProb}%）`;
    }
    weatherEl.querySelector('.summary').textContent = summary;
    weatherEl.querySelector('.temps').textContent = `最高: ${maxTemp}°C  最低: ${minTemp}°C`;
    weatherEl.classList.add('show');
    setRainVisibility(rainSoon);
  } catch {
    weatherEl.querySelector('.summary').textContent = '天気の取得に失敗しました。';
    weatherEl.classList.add('show');
    setRainVisibility(false);
  }
}

function nthWeekday(date) {
  return Math.ceil(date.getDate() / 7);
}

function getGarbage(date) {
  const dow = date.getDay();
  if (dow === 3) return { label: '燃えるごみを出す', morningOnly: true };
  if (dow === 4) return { label: '古紙・プラスチックを出す', morningOnly: false };
  if (dow === 5 && [1, 3].includes(nthWeekday(date))) return { label: '不燃ごみ・電池ごみを出す', morningOnly: false };
  if (dow === 6) return { label: '燃えるごみ・ビンカンPETを出す', morningOnly: false };
  return null;
}

function updateGarbage() {
  const today = new Date();
  const tomorrow = new Date(today);
  tomorrow.setDate(today.getDate() + 1);

  const todayEl = document.getElementById('today-garbage');
  const todayGarbage = getGarbage(today);
  if (todayEl) {
    if (todayGarbage) {
      todayEl.querySelector('span').textContent = todayGarbage.label;
      todayEl.hidden = false;
    } else {
      todayEl.hidden = true;
    }
  }

  const tomorrowEl = document.getElementById('tomorrow-garbage');
  const tomorrowGarbage = getGarbage(tomorrow);
  if (tomorrowEl) {
    if (tomorrowGarbage && !tomorrowGarbage.morningOnly) {
      tomorrowEl.querySelector('span').textContent = `明日の${tomorrowGarbage.label}`;
      tomorrowEl.hidden = false;
    } else {
      tomorrowEl.hidden = true;
    }
  }
}

function updateDinner() {
  const dinners = ['寿司', 'カレー', '焼きそば', '焼き魚', 'パスタ', '鍋', 'カレー'];
  document.getElementById('dinner').textContent = dinners[new Date().getDay()];
}

function updateSatClean() {
  const el = document.getElementById('sat-clean');
  if (el) el.hidden = new Date().getDay() !== 6;
}

setRainVisibility(false);
loadWeather();
updateGarbage();
updateDinner();
updateSatClean();
</script>
