<div class="planner">
  <div class="panel">
    <h1>毎日のタスク</h1>
    <% if @weather %>
      <div class="weather-note show">
        <%= @weather[:rain] ? "雨が降りそうです" : "天気は大きく崩れなさそう" %>
        <% if @weather[:max_temp] %>
          ／最高 <%= @weather[:max_temp] %>°C・最低 <%= @weather[:min_temp] %>°C
        <% end %>
      </div>
    <% end %>
  </div>

  <% @lists.each do |section| %>
    <div class="panel" data-controller="edit-mode">
      <header>
        <h2><%= section[:list].title %></h2>
        <button data-action="click->edit-mode#toggle" data-edit-mode-target="toggle">編集</button>
      </header>

      <ul id="list_<%= section[:list].id %>_items">
        <% section[:items].each do |item| %>
          <%= render "planner/item", item: item %>
        <% end %>
      </ul>

      <%= render "planner/add_form", list: section[:list] %>

      <textarea readonly
                placeholder="メモ..."
                data-list-id="<%= section[:list].id %>"
                data-controller="planner-note"
                data-action="blur->planner-note#save"><%= section[:list].note %></textarea>
    </div>
  <% end %>
</div>
